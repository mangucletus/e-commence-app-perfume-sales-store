# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=perfume_store
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
APP_JWT_SECRET=replace_with_64_char_hex_string
APP_JWT_EXPIRATION=86400000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local: http://localhost:3000
# Production: https://your-frontend.railway.app  or  https://your-frontend.onrender.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend Nginx proxy ───────────────────────────────────────────────────────
# Local docker-compose: leave as default (uses Docker internal hostname)
# Production: set to your deployed backend URL
BACKEND_URL=http://backend:8080

# ── Grafana (local only) ───────────────────────────────────────────────────────
# Access at http://localhost:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
